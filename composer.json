{
    "name": "salvaterol/actionable-column",
    "description": "Interactive table column with clickable actions for Filament v4 and v5",
    "keywords": [
        "filament",
        "filament-plugin",
        "table-columns",
        "actionable-column",
        "interactive-column",
        "clickable-column"
    ],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Shreejan Pandit",
            "email": "shreezanpandit@gmail.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "filament/filament": "^4.0|^5.0",
        "illuminate/support": "^12.0",
        "illuminate/database": "^12.0",
        "spatie/laravel-package-tools": "*"
    },
    "autoload": {
        "psr-4": {
            "Shreejan\\ActionableColumn\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Shreejan\\ActionableColumn\\ActionableColumnServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
