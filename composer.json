{
    "name": "shreejan/filament-actionable-columns",
    "version": "1.0.0",
    "description": "Interactive table columns with clickable actions for Filament v4",
    "keywords": [
        "filament",
        "filament-plugin",
        "table-columns",
        "actionable-columns",
        "interactive-columns",
        "clickable-columns"
    ],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Shreejan Pandit",
            "email": "shreezanpandit@gmail.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "filament/filament": "^4.0",
        "illuminate/support": "^12.0",
        "illuminate/database": "^12.0",
        "spatie/laravel-package-tools": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Shreejan\\FilamentActionableColumns\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Shreejan\\FilamentActionableColumns\\ActionableColumnsServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}